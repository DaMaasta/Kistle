# PostgreSQL
DB_HOST=192.168.0.100
DB_PORT=5432
DB_NAME=webapp
DB_USER=admin
DB_PASSWORD=sicherespasswort

# JWT (mind. 32 zufällige Zeichen — NIEMALS teilen!)
JWT_SECRET=HIER_MINDESTENS_32_ZEICHEN_LANGES_ZUFALLS_SECRET

# Google OAuth (aus Google Cloud Console)
GOOGLE_CLIENT_ID=deine-client-id.apps.googleusercontent.com

# CORS (URL der React-App)
CORS_ORIGIN=https://deine-domain.de

# Dateispeicher
DATA_PATH=/mnt/data

PORT=3000
